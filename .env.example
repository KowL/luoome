# luoome 项目级配置（复制为 .env 后填写；.env 已 gitignore，不会入库）
# 加载位置：CLI / web 启动时自动读取 <项目根>/.env 与 $LUOOME_HOME/.env
# 优先级：真实环境变量 > 项目根 .env > $LUOOME_HOME/.env

# ---------- LLM（必填真实 PROVIDER + API_KEY） ----------
# openai-compatible | anthropic
LUOOME_LLM_PROVIDER=openai-compatible
LUOOME_LLM_API_KEY=
# 缺省模型：gpt-4o-mini（openai-compatible）/ claude-haiku-4-5（anthropic）
# LUOOME_LLM_MODEL=kimi-k2-0905-preview
# 国内 OpenAI 兼容服务改这里，如 https://api.moonshot.cn/v1
# LUOOME_LLM_BASE_URL=https://api.openai.com/v1

# ---------- 行情（必填；Eastmoney 主 → Tencent 备） ----------
LUOOME_MARKET_PROVIDER=real

# ---------- 数据目录（缺省 ~/.luoome） ----------
# LUOOME_HOME=/path/to/.luoome

# ---------- AdShare 数据服务（未配置时自动回退本地行情） ----------
# adshare 服务根地址。SDK 会去掉末尾的 /。
# 优先使用域名（例如 https://adshare.example.internal），不要硬编码 IP。
ADSHARE_URL=

# 同时作为 X-API-Key 与 Authorization: Bearer *** 头发送。
# 远端不强制鉴权时可留空字符串。
ADSHARE_API_KEY=

# 单次请求尝试的超时（毫秒）。SDK 默认 10000。
ADSHARE_TIMEOUT_MS=10000

# 网络错误 / 5xx 时最大重试次数（不含首次尝试）。
# SDK 默认 2（首次 + 2 次重试 = 3 次）。
ADSHARE_MAX_RETRIES=2
