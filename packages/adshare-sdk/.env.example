# @luoome/adshare-sdk runtime config
# Copy to .env and fill in real values before running the SDK against a remote adshare instance.

# Base URL of the adshare HTTP service, e.g. https://adshare.luoome.local or http://8.148.216.30:8888 for LAN dev.
ADSHARE_URL=

# API key for the adshare service. Optional when the remote has auth_enabled=false (e.g. local mock);
# leave blank in that case. Set via secret manager / .env in production — never commit to git.
ADSHARE_API_KEY=

# Per-attempt request timeout in milliseconds.
ADSHARE_TIMEOUT_MS=10000

# Maximum retries after the initial request. Only network errors and 5xx are retried.
ADSHARE_MAX_RETRIES=2
